## Lorax template (passed to build-container-installer via additional_templates).
## It patches the *installer environment* (the Anaconda boot.iso runtime), not
## the installed system, so the end-of-install reboot doesn't hang on a grey
## screen waiting to tear down the live installer root.
##
## Anaconda reboots with `systemctl --no-wall reboot` (no --force), which runs
## the full systemd shutdown and can stall unmounting the busy installer medium.
## Two belt-and-suspenders overrides force it through:
##
## 1. systemd-reboot.service -> `systemctl --force --force reboot`, i.e. the
##    reboot(2) syscall directly, skipping systemd-shutdown's unmount loop.
## 2. DefaultTimeoutStopSec=15s so a hung stop job earlier in the transition is
##    abandoned quickly instead of blocking forever.
##
## Paths are relative to the installer root, matching the repo's other templates.
mkdir etc/systemd/system/systemd-reboot.service.d
append etc/systemd/system/systemd-reboot.service.d/00-force.conf "[Service]"
append etc/systemd/system/systemd-reboot.service.d/00-force.conf "ExecStart="
append etc/systemd/system/systemd-reboot.service.d/00-force.conf "ExecStart=systemctl --force --force reboot"

mkdir etc/systemd/system.conf.d
append etc/systemd/system.conf.d/00-fast-shutdown.conf "[Manager]"
append etc/systemd/system.conf.d/00-fast-shutdown.conf "DefaultTimeoutStopSec=15s"
